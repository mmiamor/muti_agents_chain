# ── LLM API──
OPENAI_API_KEY=your_zhipu_api_key_here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
DEFAULT_MODEL=GLM-5-Turbo

# ── Agent 模型配置（可选）──
# 如果不配置，将使用 DEFAULT_MODEL
# PM_MODEL=glm-4-plus           # PM Agent 专用模型
# ARCHITECT_MODEL=glm-4-plus    # Architect Agent 专用模型
# DESIGN_MODEL=glm-4-plus       # Design Agent 专用模型
# BACKEND_DEV_MODEL=glm-4-plus  # Backend Dev Agent 专用模型
# FRONTEND_DEV_MODEL=glm-4-plus # Frontend Dev Agent 专用模型
# QA_MODEL=glm-4-plus           # QA Agent 专用模型
# REVIEWER_MODEL=glm-4-plus     # Reviewer Agent 专用模型

# ── 服务配置 ──
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# ── 性能优化 ──
NODE_DELAY=8# 节点间延迟（避免限流）
LLM_RETRY_MAX=5# 最大重试次数
LLM_RETRY_BASE_DELAY=8# 重试延迟
LLM_TIMEOUT=300# 超时时间（5分钟）

# ── 上下文管理 ──
MAX_CONTEXT_MESSAGES=100
MAX_CONTEXT_TOKENS=8000
COMPACT_THRESHOLD=0.8

# ── Agent 配置 ──
MAX_REVISION_COUNT=2# 最大修改次数（降低重试）
RECURSION_LIMIT=30
STREAM_ENABLED=true

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── 数据库 ──
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
